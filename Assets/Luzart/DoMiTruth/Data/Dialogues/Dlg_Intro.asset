  m_Script: {fileID: 11500000, guid: 0526cf07aa76fe74f94735dbb15f626e, type: 3}
  m_Name: Dlg_Intro
  m_EditorClassIdentifier: 
  dialogueId: intro
  lines:
  - character: {fileID: 11400000, guid: 44aca2fbae16e9a44961a10fa930477c, type: 2}
    text: '- Comrade, a dismemberment homicide has been discovered at the Indochine
      villa. The victim has been tentatively identified as the OWNER of the house'
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 44aca2fbae16e9a44961a10fa930477c, type: 2}
    text: '- Four suspects with both motive and capability have been identified'
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 44aca2fbae16e9a44961a10fa930477c, type: 2}
    text: '- The case still contains many blind spots. Proceed with caution. These
      are the essential information of the case'
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 9b89d477ed6fc0d4f93157527a06fd71, type: 2}
    text: ' - ...'
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 9b89d477ed6fc0d4f93157527a06fd71, type: 2}
    text: ' - ...'
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 9b89d477ed6fc0d4f93157527a06fd71, type: 2}
    text: '- Thank you sir'
    typingSpeed: 30
    waitForInput: 1
  autoAdvance: 0
  autoAdvanceDelay: 2
