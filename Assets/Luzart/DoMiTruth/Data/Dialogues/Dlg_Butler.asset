  dialogueId: butler_talk
  lines:
  - character: {fileID: 11400000, guid: c0a8775af16a95e40a6158d66d13cdab, type: 2}
    text: Toi da lam viec o day 10 nam roi.
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: c0a8775af16a95e40a6158d66d13cdab, type: 2}
    text: Dem qua toi o phong rieng, khong nghe thay gi.
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 9b89d477ed6fc0d4f93157527a06fd71, type: 2}
    text: Ong co biet ai co the muon hai chu nha?
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: c0a8775af16a95e40a6158d66d13cdab, type: 2}
    text: ...Toi khong dam noi.
    typingSpeed: 30
    waitForInput: 1
  autoAdvance: 0
  autoAdvanceDelay: 2
