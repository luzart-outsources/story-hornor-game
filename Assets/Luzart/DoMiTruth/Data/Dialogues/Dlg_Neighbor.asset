  lines:
  - character: {fileID: 11400000, guid: 1a52856b3ea809c4985183ef32aa3d11, type: 2}
    text: Toi thay mot nguoi la o gan nha luc khuya.
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 9b89d477ed6fc0d4f93157527a06fd71, type: 2}
    text: Nguoi do trang nhu the nao?
    typingSpeed: 30
    waitForInput: 1
  - character: {fileID: 11400000, guid: 1a52856b3ea809c4985183ef32aa3d11, type: 2}
    text: Mac ao khoac den, doi mu. Khong nhin ro mat.
    typingSpeed: 30
    waitForInput: 1
