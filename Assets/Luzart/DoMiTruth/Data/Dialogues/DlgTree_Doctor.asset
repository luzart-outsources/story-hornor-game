%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d8a2b2adee5c2406fb0c50c44244ff03, type: 3}
  m_Name: DlgTree_Doctor
  m_EditorClassIdentifier: 
  dialogueId: dlg_doctor
  npcCharacter: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
  playerCharacter: {fileID: 11400000, guid: 9b89d477ed6fc0d4f93157527a06fd71, type: 2}
  greetingLines:
  - character: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
    text: I'm just a doctor. I truly have nothing to do with this.
    typingSpeed: 30
    waitForInput: 1
  choices:
  - choiceLabel: The victim's medical records
    npcMoodAnimator: {fileID: 9100000, guid: 958377f1b251b4c928cc6825c9191f6c, type: 2}
    npcMoodSprite: {fileID: 0}
    responseLines:
    - character: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
      text: She suffered from insomnia and frequently requested sleeping pills.
      typingSpeed: 30
      waitForInput: 1
    - character: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
      text: She had been under significant stress lately and was often irritable.
      typingSpeed: 30
      waitForInput: 1
    - character: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
      text: Other than that, she had been fine, had no known medical conditions.
      typingSpeed: 30
      waitForInput: 1
    testimonyCue: {fileID: 0}
    hideAfterChosen: 1
  - choiceLabel: Relationship with the victim
    npcMoodAnimator: {fileID: 9100000, guid: dada17ff13dab42d2a5fbb0e0d3387d0, type: 2}
    npcMoodSprite: {fileID: 0}
    responseLines:
    - character: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
      text: We partnered to open a private clinic, but we have recently encountered
        a little disagreement.
      typingSpeed: 30
      waitForInput: 1
    - character: {fileID: 11400000, guid: fbeb02cbf0fa948ffa5ccb963f44e202, type: 2}
      text: "She kept refusing to sign the investment agreement, giving various reasons
        \u2014 like waiting for paperwork, to concerns about feng shui numbers, or
        claiming she saw no benefit in the investment."
      typingSpeed: 30
      waitForInput: 1
    testimonyCue: {fileID: 0}
    hideAfterChosen: 1
  farewellLines: []
